<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
body{
margin:0;
font-family:sans-serif;
background:linear-gradient(135deg,#1e1e1e,#3a3a3a);
color:#fff;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
}

.card{
width:90%;
max-width:380px;
background:rgba(255,255,255,0.05);
border-radius:25px;
padding:30px;
text-align:center;
backdrop-filter:blur(20px);
}

.name{font-size:26px;font-weight:bold}
.company{color:#ccc;margin-top:5px}

.btn{
display:block;
margin:12px 0;
padding:14px;
border-radius:12px;
text-decoration:none;
color:#fff;
}

.line{background:#06C755}
.fb{background:#1877F2}
.web{background:#444}
</style>
</head>

<body>

<div class="card">
<div class="name"></div>
<div class="company"></div>

<a class="btn web" id="web">網站</a>
<a class="btn line" id="line">LINE</a>
<a class="btn fb" id="fb">Facebook</a>
</div>

<script>

const API="https://script.google.com/macros/s/AKfycby8qtUxJnbD80KsR5k-dK7vphQ0Q4zvcjRIEZ3xxxroWjFIG779gOPVk7UR3gbpYKCe/exec";
const id=new URLSearchParams(location.search).get("id");

fetch(API+"?action=get&id="+id)
.then(r=>r.json())
.then(d=>{
document.querySelector(".name").innerText=d.name||"";
document.querySelector(".company").innerText=d.company||"";

if(d.website) web.href=d.website; else web.style.display="none";
if(d.line) line.href=d.line; else line.style.display="none";
if(d.fb) fb.href=d.fb; else fb.style.display="none";
});

</script>

</body>
</html>
